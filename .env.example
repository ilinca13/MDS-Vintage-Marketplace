# Copy this file to .env and fill in real values.
# .env is git-ignored; .env.example is committed.

# --- PostgreSQL ---
POSTGRES_DB=vintage_marketplace
POSTGRES_USER=vintage_user
POSTGRES_PASSWORD=change_me_before_production

# --- Django ---
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DEBUG=True

# --- Django superuser (created automatically on first docker compose up) ---
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change_me_before_production
